# ── Required: Polymarket wallet (proxy/funder signing, signature_type=3) ──
PRIVATE_KEY=0xyour_signer_private_key
FUNDER_ADDRESS=0xyour_polymarket_funder_address

# ── Required: Telegram (the bot asks YOU before every buy and sell) ──
# Token from @BotFather. CHAT_ID(s) allowed to control the bot; the first
# one receives new trade cards. Comma-separate for multiple people.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here
TELEGRAM_CHAT_ID=123456789

# ── Signal + state files ──
# On Railway, point these at a volume shared with the forecast bot,
# e.g. /data/signals.json and /data/trader_state.json
SIGNALS_FILE=signals.json
STATE_FILE=trader_state.json

# ── Amount presets shown as buttons (you can also type a custom amount) ──
DEFAULT_UNIT=USD          # USD or SHARES (which unit is selected first)
USD_PRESETS=1,5,10,25,50  # $1 = Polymarket's ~minimum order, good for testing
SHARE_PRESETS=5,10,25,50

# ── Entry / exit ──
ENTRY_MAX=0.97            # hard ceiling on price ever paid
ENTRY_BUFFER=0.01         # how far above ask we bid to cross the book
TP_PRICE=0.90             # take-profit prompt level (per-signal can override)
SL_PRICE=0.20             # stop-loss prompt level
SL_CROSS_BUFFER=0.02      # when you approve a sell, cross book by this
SL_FLOOR=0.02             # never sell below this
MAX_HOLD_HOURS=30         # fall back to resolution after this if no exit

# ── Cadence ──
SIGNAL_POLL_S=5
MONITOR_POLL_S=5
FILL_TIMEOUT_S=45
HTTP_TIMEOUT_S=5

# ── Safety: true = log orders WITHOUT sending them (rehearse the flow) ──
DRY_RUN=true
